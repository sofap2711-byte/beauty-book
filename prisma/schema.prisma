generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL")
}

model Service {
  id          String   @id @default(uuid())
  name        String
  description String?
  category    String
  subServices SubService[]
  masters     Master[]
  createdAt   DateTime @default(now())
}

model SubService {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       String
  serviceId   String
  service     Service  @relation(fields: [serviceId], references: [id])
}

model Master {
  id          String   @id @default(uuid())
  name        String
  photo       String?
  role        String
  rating      Int      @default(5)
  instagram   String?
  workDays    String
  startTime   String
  endTime     String
  email       String?  @unique
  password    String?
  isActive    Boolean  @default(true)
  serviceId   String
  service     Service  @relation(fields: [serviceId], references: [id])
  timeBlocks  TimeBlock[]
}

model TimeBlock {
  id          String   @id @default(uuid())
  masterId    String
  master      Master   @relation(fields: [masterId], references: [id])
  date        DateTime @db.Date
  startTime   String
  endTime     String
  type        String   // "booking" | "blocked"
  clientName  String?
  clientPhone String?
  clientTg    String?
  serviceName String?
  comment     String?
  adminNotes  String?
  source      String   @default("manual") // "online" | "manual"
  status      String   @default("confirmed") // "confirmed" | "completed" | "cancelled" | "no-show"
  createdAt   DateTime @default(now())

  @@index([masterId, date])
}
