generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL")
}

model Service {
  id          String   @id @default(uuid())
  name        String
  description String?
  category    String
  subServices SubService[]
  masters     Master[]
  createdAt   DateTime @default(now())
}

model SubService {
  id          String   @id @default(uuid())
  name        String
  description String?
  price       String
  serviceId   String
  service     Service  @relation(fields: [serviceId], references: [id])
}

model Master {
  id          String   @id @default(uuid())
  name        String
  photo       String?
  role        String
  rating      Int      @default(5)
  instagram   String?
  workDays    String
  startTime   String
  endTime     String
  breakStart  String?
  breakEnd    String?
  serviceId   String
  service     Service  @relation(fields: [serviceId], references: [id])
  slots       Slot[]
}

model Slot {
  id          String   @id @default(uuid())
  masterId    String
  master      Master   @relation(fields: [masterId], references: [id])
  date        String
  time        String
  status      String   @default("free")
  clientName  String?
  clientPhone String?
  clientTg    String?
  comment     String?
  booking     Booking?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([masterId, date, time])
}

model Booking {
  id          String   @id @default(uuid())
  slotId      String   @unique
  slot        Slot     @relation(fields: [slotId], references: [id])
  clientName  String
  clientPhone String
  clientTg    String?
  comment     String?
  status      String   @default("new")
  adminNotes  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
